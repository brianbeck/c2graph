# =============================================================================
# Sentinel - Solana Fraud Detection Graph
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# -- Neo4j --
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel-dev-password

# -- RabbitMQ --
RABBITMQ_URI=amqp://guest:guest@localhost:5672/
RABBITMQ_MANAGEMENT_PORT=15672

# -- Solana RPC --
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_RATE_LIMIT=2

# -- Supabase (Cloud Free Tier - Auth Only) --
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# -- API Gateway --
API_PORT=8080
API_CORS_ORIGIN=http://localhost:5173

# -- Worker --
WORKER_CONCURRENCY=4
BATCH_SIZE=50
MAX_WALLETS_PER_SCAN=10000
SCAN_FRESHNESS_HOURS=24

# -- Frontend (prefixed with VITE_ for Vite) --
VITE_API_URL=http://localhost:8080
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
